{
  "name": "muxy-starter-vanilla",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build"
  },
  "devDependencies": {
    "vite": "^7.3.5"
  },
  "muxy": {
    "$schema": "https://raw.githubusercontent.com/muxy-app/muxy/main/docs/extensions/schema/manifest.schema.json",
    "description": "Vanilla JS starter kit for Muxy extensions",
    "permissions": ["panels:write"],
    "panels": [
      {
        "id": "hello",
        "title": "Hello",
        "icon": { "symbol": "sparkles" },
        "entry": "panel/index.html",
        "position": "right",
        "mode": "pinned",
        "headerButtons": [
          {
            "id": "refresh",
            "icon": { "symbol": "arrow.clockwise" },
            "tooltip": "Refresh",
            "command": "refresh-hello"
          }
        ]
      }
    ],
    "commands": [
      {
        "id": "toggle-hello",
        "title": "Starter: Toggle Hello Panel",
        "defaultShortcut": "cmd+shift+h",
        "action": { "kind": "togglePanel", "panel": "hello" }
      },
      {
        "id": "refresh-hello",
        "title": "Starter: Refresh Hello Panel"
      }
    ],
    "topbarItems": [
      {
        "id": "hello",
        "icon": { "symbol": "sparkles" },
        "tooltip": "Toggle Hello Panel",
        "command": "toggle-hello"
      }
    ]
  }
}
